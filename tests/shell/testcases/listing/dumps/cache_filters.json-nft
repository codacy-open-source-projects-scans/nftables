    {
      "chain": {
        "family": "ip",
        "table": "ip_t",
        "name": "ip_t_c",
        "handle": 0
      }
    },
    {
      "chain": {
        "family": "ip",
        "table": "ip_t",
        "name": "ip_t_c2",
        "handle": 0
      }
    },
    {
      "set": {
        "family": "ip",
        "name": "ip_t_s",
        "table": "ip_t",
        "type": "inet_service",
        "handle": 0,
        "elem": [
          22,
          80,
          443
        ]
      }
    },
    {
      "flowtable": {
        "family": "ip",
        "name": "ip_t_ft",
        "table": "ip_t",
